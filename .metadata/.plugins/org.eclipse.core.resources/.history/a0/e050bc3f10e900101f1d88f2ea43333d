package com.practicehub.backend.controller;

import com.practicehub.backend.model.Workspace;
import com.practicehub.backend.repository.WorkspaceRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api")
@CrossOrigin
public class WorkspaceController {

    @Autowired
    private WorkspaceRepository repo;   // ✅ THIS FIXES THE ERROR

    @GetMapping("/workspace/{username}")
    public Workspace get(@PathVariable String username) {
        return repo.findByUsername(username).orElse(null);
    }

    @PostMapping("/workspace/{username}")
    public Workspace save(@PathVariable String username,
                          @RequestBody Workspace incoming) {

        Workspace existing = repo.findByUsername(username).orElse(null);

        // 🔥 CRITICAL FIX: prevent erase
        if (incoming.getWorkspace() == null || incoming.getWorkspace().isEmpty()) {
            return existing;
        }

        if (existing != null) {
            existing.setWorkspace(incoming.getWorkspace());
            return repo.save(existing);
        }

        incoming.setUsername(username);
        return repo.save(incoming);
    }
}
