package com.practicehub.controller;

import com.practicehub.entity.Folder;
import com.practicehub.entity.FileEntity;
import com.practicehub.repository.FolderRepository;
import com.practicehub.repository.FileRepository;
import org.springframework.web.bind.annotation.*;

import java.util.HashMap;
import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("/api/workspace")
@CrossOrigin(origins = "*")
public class WorkspaceController {

    private final FolderRepository folderRepo;
    private final FileRepository fileRepo;

    public WorkspaceController(FolderRepository folderRepo, FileRepository fileRepo) {
        this.folderRepo = folderRepo;
        this.fileRepo = fileRepo;
    }

    // LOAD WORKSPACE
    @GetMapping("/{userId}")
    public Map<String, Object> loadWorkspace(@PathVariable Long userId) {
        List<Folder> folders = folderRepo.findByUserId(userId);
        List<FileEntity> files = fileRepo.findByUserId(userId);

        Map<String, Object> res = new HashMap<>();
        res.put("folders", folders);
        res.put("files", files);
        return res;
    }

    // CREATE FOLDER
    @PostMapping("/folder")
    public Folder createFolder(@RequestBody Folder folder) {
        return folderRepo.save(folder);
    }

    // CREATE FILE
    @PostMapping("/file")
    public FileEntity createFile(@RequestBody FileEntity file) {
        return fileRepo.save(file);
    }

    // SAVE FILE CONTENT
    @PutMapping("/file/{id}")
    public FileEntity saveFile(
            @PathVariable Long id,
            @RequestBody FileEntity updated
    ) {
        FileEntity f = fileRepo.findById(id).orElseThrow();
        f.setContent(updated.getContent());
        return fileRepo.save(f);
    }

    // DELETE FILE
    @DeleteMapping("/file/{id}")
    public void deleteFile(@PathVariable Long id) {
        fileRepo.deleteById(id);
    }

    // DELETE FOLDER
    @DeleteMapping("/folder/{id}")
    public void deleteFolder(@PathVariable Long id) {
        folderRepo.deleteById(id);
    }
}
